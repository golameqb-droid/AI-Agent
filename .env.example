# ==========================================================================
#  SocialAI Pro — Platform Configuration
#  Copy this file to ".env" and fill in your real values.
# ==========================================================================

# ---- Server ----
PORT=3000
# Public URL for product images (HTTPS required for Facebook Messenger attachments)
# Use your cloudflared/ngrok URL in production, e.g. https://abc.trycloudflare.com
PUBLIC_BASE_URL=https://socialaipro-app.equestionbankbd.com

# ---- Platform Auth (SocialAI Pro) ----
JWT_SECRET=change-this-to-a-long-random-secret
SUPER_ADMIN_EMAIL=golarambbi620@gmail.com
SUPER_ADMIN_PASSWORD=Golam123@#1

# Legacy dashboard login (deprecated — use vendor register/login)
DASHBOARD_USER=admin
DASHBOARD_PASS=changeme

# ---- AI Provider (FREE options) ----
# Choose: "gemini" (Google, free tier) or "groq" (free, very fast)
AI_PROVIDER=gemini

# Google Gemini — get a FREE key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq — get a FREE key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# Anthropic Claude — https://console.anthropic.com/
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-3-5-haiku-20241022

# ---- Facebook / Meta (platform webhook — shared across all vendors) ----
# From your Facebook App (see SETUP_FACEBOOK.md for a full guide)
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
# Any random secret string you make up — used to verify the webhook
FB_VERIFY_TOKEN=socialai_pro_verify_secret_123
FB_GRAPH_VERSION=v21.0

# ---- Behaviour ----
# If "true", the agent replies automatically. If "false", it only creates
# drafts that you approve from the dashboard. Start with "false".
AUTO_REPLY_MESSAGES=false
AUTO_REPLY_COMMENTS=false

# Language style for replies: banglish | bangla | english | auto
REPLY_LANGUAGE=banglish

# ---- Bangladesh Payments (optional — prefer Super Admin → Payment Config UI) ----
BKASH_APP_KEY=
BKASH_APP_SECRET=
BKASH_USERNAME=
BKASH_PASSWORD=
BKASH_MERCHANT_NUMBER=
BKASH_SANDBOX=true
NAGAD_MERCHANT_ID=
NAGAD_MERCHANT_NUMBER=
NAGAD_PUBLIC_KEY=
NAGAD_PRIVATE_KEY=
NAGAD_SANDBOX=true
SSLCOMMERZ_STORE_ID=
SSLCOMMERZ_STORE_PASS=
SSLCOMMERZ_SANDBOX=true
SALES_EMAIL=sales@socialai.pro
SALES_WHATSAPP=
