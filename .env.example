# ==========================================================================
#  eQuestionBankBD AI Agent — Environment Configuration
#  Copy this file to ".env" and fill in your real values.
# ==========================================================================

# ---- Server ----
PORT=3000
# Username/password to log into the dashboard
DASHBOARD_USER=admin
DASHBOARD_PASS=changeme

# ---- AI Provider (FREE options) ----
# Choose: "gemini" (Google, free tier) or "groq" (free, very fast)
AI_PROVIDER=gemini

# Google Gemini — get a FREE key at https://aistudio.google.com/app/apikey
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.0-flash

# Groq — get a FREE key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.3-70b-versatile

# ---- Facebook / Meta ----
# From your Facebook App (see SETUP_FACEBOOK.md for a full guide)
FB_PAGE_ID=
FB_PAGE_ACCESS_TOKEN=
# Any random secret string you make up — used to verify the webhook
FB_VERIFY_TOKEN=equestionbankbd_verify_secret_123
FB_GRAPH_VERSION=v21.0

# ---- Behaviour ----
# If "true", the agent replies automatically. If "false", it only creates
# drafts that you approve from the dashboard. Start with "false".
AUTO_REPLY_MESSAGES=false
AUTO_REPLY_COMMENTS=false

# Language style for replies: banglish | bangla | english | auto
REPLY_LANGUAGE=banglish
