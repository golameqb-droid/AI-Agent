{
  "name": "equestionbankbd-ai-agent",
  "version": "1.0.0",
  "description": "AI agent that manages the eQuestionBankBD Facebook page: auto-replies to comments and messages, creates and schedules posts, and answers customers in Banglish.",
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "start": "tsx src/index.ts",
    "build": "tsc -p tsconfig.json",
    "serve": "node dist/index.js",
    "typecheck": "tsc --noEmit"
  },
  "keywords": [
    "facebook",
    "ai-agent",
    "messenger",
    "automation",
    "equestionbankbd"
  ],
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^11.3.0",
    "dotenv": "^16.4.5",
    "express": "^4.21.0",
    "node-cron": "^3.0.3"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.11",
    "@types/express": "^4.17.21",
    "@types/node": "^22.7.4",
    "@types/node-cron": "^3.0.11",
    "tsx": "^4.19.1",
    "typescript": "^5.6.2"
  }
}
